<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #0d1b2a, #000000);
        color: white;
    }

    /* HERO */
    .hero {
        text-align: center;
        padding: 60px 20px;
    }

    .hero img {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #4da6ff;
        box-shadow: 0 0 20px rgba(0,0,255,0.6);
    }

    .highlight {
        color: #4da6ff;
        font-weight: bold;
    }

    /* GLASS CARD */
    .glass {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 0 15px rgba(0,0,255,0.2);
    }

    /* TABLE */
    table {
        border-radius: 10px;
        overflow: hidden;
    }

    /* LIST */
    .list-lagu li {
        background: rgba(0,0,225,0.2);
        margin: 8px 0;
        padding: 10px;
        border-radius: 8px;
        border-left: 4px solid #4da6ff;
        transition: 0.3s;
    }

    .list-lagu li:hover {
        background: rgba(0,0,225,0.5);
        transform: translateX(8px);
    }

    /* SECTION TITLE */
    .section-title {
        text-align: center;
        margin-bottom: 20px;
        color: #4da6ff;
    }

</style>
</head>

